# Dependencies (installed fresh in the build stage)
node_modules

# Build output (regenerated by `npm run build` inside the image)
dist
dist-ssr

# Version control
.git
.gitignore

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor / OS cruft
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.local

# Never bake secrets into the image
.env
.env.*
